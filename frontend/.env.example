# ============================================================
# KanbanDL Frontend — Environment Variables
# ============================================================
# Copy this file to .env.local for local development.
# For PRODUCTION (Vercel), set these in the Vercel Dashboard:
#   Project Settings → Environment Variables → Production
# ============================================================

# URL of the Node.js backend API (no trailing slash)
VITE_API_URL=https://kanbandl.onrender.com/api

# URL of the Node.js backend root (for Socket.io)
VITE_SOCKET_URL=https://kanbandl.onrender.com
